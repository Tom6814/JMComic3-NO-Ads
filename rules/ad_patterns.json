{
  "file_globs": [
    "assets/public/static/js/*.js",
    "assets/public/static/css/*.css",
    "assets/public/index.html",
    "assets/public/manifest.json"
  ],
  "scan_file_globs": [
    "assets/public/static/js/*.js",
    "assets/public/index.html",
    "assets/public/asset-manifest.json",
    "assets/public/manifest.json"
  ],
  "string_blocklist": [
    "admob",
    "doubleclick.net",
    "gdt",
    "pangle",
    "bytedance"
  ],
  "regex_rewrites": [
    {
      "name": "disable_ad_init_common",
      "pattern": "(?s)\\b(initAd|initAds|loadAd|loadAds)\\s*\\(",
      "replace": "(function(){return;})("
    },
    {
      "name": "rename_custom_ad",
      "pattern": "custom_ad",
      "replace": "cover_default"
    },
    {
      "name": "disable_ads_cache_read",
      "pattern": "i=JSON\\.parse\\(localStorage\\.getItem\\(\\\"adsList\\\"\\)\\)\\|\\|\\{\\}",
      "replace": "i={}"
    },
    {
      "name": "disable_ads_cache_write",
      "pattern": "localStorage\\.setItem\\(\\\"adsList\\\",JSON\\.stringify\\(a\\)\\)",
      "replace": "0"
    },
    {
      "name": "disable_ads_content_cache_write",
      "pattern": "localStorage\\.setItem\\(\\\"adsContent\\\",JSON\\.stringify\\(n\\.data\\)\\)",
      "replace": "0"
    },
    {
      "name": "disable_cover_ads_dispatch",
      "pattern": "200===n\\.code&&\\(e\\(n\\),t\\(\\(0,o\\.W_\\)\\(n\\.data\\)\\),0\\)",
      "replace": "200===n.code&&(e(n),0,0)"
    },
    {
      "name": "disable_all_ads_dispatch",
      "pattern": "i&&t\\(\\(0,o\\.k_\\)\\(i\\)\\),e\\(n\\)",
      "replace": "0,e(n)"
    },
    {
      "name": "disable_devtools_redirect_if",
      "pattern": "if\\(window\\.location\\.href\\.includes\\(\\\"devapp\\\"\\)\\)return alert\\(e\\(\\\"modal\\.devtools_blocked\\\"\\)\\),void\\(window\\.location\\.href=\\\"https://comicloveu\\.com/\\\"\\);",
      "replace": "if(window.location.href.includes(\"devapp\"))return;"
    },
    {
      "name": "disable_devtools_redirect_url",
      "pattern": "window\\.location\\.href=\\\"https://comicloveu\\.com/\\\"",
      "replace": "window.location.href=window.location.href"
    },
    {
      "name": "disable_cover_ads_content_usage",
      "pattern": "p=localStorage\\.getItem\\(\\\"adsContent\\\"\\),f=p\\?JSON\\.parse\\(p\\):Object\\.keys\\(g\\|\\|\\{\\}\\)\\.length>0\\?g:\\{\\}",
      "replace": "p=localStorage.getItem(\"adsContent\"),f={}"
    },
    {
      "name": "disable_thewayhome_route_keylist",
      "pattern": "h=\\[\\\"app_thewayhome\\\"\\]",
      "replace": "h=[]"
    },
    {
      "name": "disable_feed_inline_ads_1",
      "pattern": "!r\\.ad_free&&i>0&&i%10===0",
      "replace": "!1"
    },
    {
      "name": "disable_feed_inline_ads_2",
      "pattern": "!s\\.ad_free&&\\(t\\+1\\)%10===1&&0!==t",
      "replace": "!1"
    },
    {
      "name": "mark_title_adfree",
      "pattern": "<title>JMComic3</title>",
      "replace": "<title>JMComic3 AdFree</title>"
    },
    {
      "name": "block_external_ad_landing",
      "pattern": "<script defer=\\\"defer\\\" src=\\\"/static/js/main",
      "replace": "<script>!function(){try{var b=[\"jmcomicne.net\",\"comicloveu.com\"],c=function(u){u=String(u||\"\");for(var i=0;i<b.length;i++)if(u.indexOf(b[i])!==-1)return!0;return!1},A=Location.prototype.assign,R=Location.prototype.replace;Location.prototype.assign=function(u){return c(u)?void 0:A.call(this,u)};Location.prototype.replace=function(u){return c(u)?void 0:R.call(this,u)};var o=window.open;window.open=function(u){return c(u)?null:o.apply(this,arguments)}}catch(e){}}();</script><script defer=\\\"defer\\\" src=\\\"/static/js/main"
    },
    {
      "name": "mark_manifest_adfree",
      "pattern": "\"name\": \"JMComic3\"",
      "replace": "\"name\": \"JMComic3 AdFree\""
    },
    {
      "name": "mark_manifest_shortname_adfree",
      "pattern": "\"short_name\": \"JMComic3\"",
      "replace": "\"short_name\": \"JMComic3 AdFree\""
    },
    {
      "name": "disable_clarity_loader",
      "pattern": "\"localhost\"===window\\.location\\.hostname\\|\\|window\\.location\\.href\\.includes\\(\"devapp\"\\)\\|\\|function",
      "replace": "\"localhost\"===window.location.hostname||true||function"
    },
    {
      "name": "remove_clarity",
      "pattern": "c\\.src=\\\"https://www\\\\.clarity\\\\.ms/tag/[^\\\"]+\\\",\\(i=e\\.getElementsByTagName\\(o\\)\\[0\\]\\)\\.parentNode\\.insertBefore\\(c,i\\)",
      "replace": "0"
    }
  ],
  "resource_drop_globs": [
    "assets/public/images/*ad*.*",
    "assets/public/images/custom_ad.*"
  ]
}
